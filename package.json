  "build": {
    "appId": "com.fourninecloud.turul",
    "productName": "Turul",
    "directories": {
      "output": "release"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "sign": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "overrides": {
    "fast-xml-parser": "^5.5.6",
    "node-forge": "^1.4.0",
    "protobufjs": "^7.2.5",
    "@grpc/grpc-js": "^1.8.22",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
